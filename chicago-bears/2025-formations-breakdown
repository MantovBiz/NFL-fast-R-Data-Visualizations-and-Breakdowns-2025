# ── Defense: Man vs Zone Coverage ─────────────────────────────────────────────
# Cover 0, Cover 1, Cover 2 Man = Man coverage
# Cover 2, Cover 3, Cover 4, Cover 6, Cover 9 = Zone coverage
# Combo = Mixed (could be either)
man_vs_zone <- pbp %>%
  filter(
    pass == 1,
    play_type == "pass",
    two_point_attempt == 0,
    defteam == "CHI"
  ) %>%
  mutate(
    coverage_type = case_when(
      defense_coverage_type %in% c("COVER_0", "COVER_1", "2_MAN")        ~ "Man",
      defense_coverage_type %in% c("COVER_2", "COVER_3", "COVER_4",
                                   "COVER_6", "COVER_9")                 ~ "Zone",
      defense_coverage_type == "COMBO"                                    ~ "Mixed",
      TRUE                                                                ~ NA_character_
    ),
    season_type = if_else(season_type == "REG", "Regular Season", "Playoffs")
  ) %>%
  filter(!is.na(coverage_type)) %>%
  group_by(season_type, coverage_type) %>%
  summarise(
    Plays   = n(),
    EPA     = mean(epa,          na.rm = TRUE),
    Success = mean(success,      na.rm = TRUE),
    YPP     = mean(yards_gained, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(pct = Plays / sum(Plays)) %>%
  arrange(season_type, desc(Plays))

# ── Defense: Man vs Zone Table ────────────────────────────────────────────────
man_vs_zone_table <- man_vs_zone %>%
  mutate(Team = chi_wordmark) %>%
