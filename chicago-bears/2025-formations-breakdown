# ── Defense: Formation Helper Function ───────────────────────────────────────
# Extracts DL, LB, DB counts from the raw personnel string and maps to a
# formation name. Used for both full season and split tables below.
add_formation <- function(df) {
  df %>%
    mutate(
      # ── DL (DE + DT) ───────────────────────────────────────────────────────
      de = as.numeric(str_extract(defense_personnel, "\\d+(?= DE)")) %>% replace_na(0),
      dt = as.numeric(str_extract(defense_personnel, "\\d+(?= DT)")) %>% replace_na(0),
      dl = de + dt,
      
      # ── LB (MLB + OLB + ILB) ──────────────────────────────────────────────
      mlb = as.numeric(str_extract(defense_personnel, "\\d+(?= MLB)")) %>% replace_na(0),
      olb = as.numeric(str_extract(defense_personnel, "\\d+(?= OLB)")) %>% replace_na(0),
      ilb = as.numeric(str_extract(defense_personnel, "\\d+(?= ILB)")) %>% replace_na(0),
      lb  = mlb + olb + ilb,
      
      # ── DB (CB + FS + SS) ─────────────────────────────────────────────────
      cb = as.numeric(str_extract(defense_personnel, "\\d+(?= CB)")) %>% replace_na(0),
      fs = as.numeric(str_extract(defense_personnel, "\\d+(?= FS)")) %>% replace_na(0),
      ss = as.numeric(str_extract(defense_personnel, "\\d+(?= SS)")) %>% replace_na(0),
      db = cb + fs + ss,
      
      # ── Map to formation name ──────────────────────────────────────────────
      formation = case_when(
        dl == 4 & lb == 2 & db == 5 ~ "Nickel (4-2-5)",
        dl == 4 & lb == 1 & db == 6 ~ "Dime (4-1-6)",
        dl == 4 & lb == 3 & db == 4 ~ "Base 4-3",
        dl == 3 & lb == 4 & db == 4 ~ "Base 3-4",
        dl == 3 & lb == 3 & db == 5 ~ "Nickel (3-3-5)",
        dl == 3 & lb == 2 & db == 6 ~ "Dime (3-2-6)",
        dl == 5 & lb == 1 & db == 5 ~ "Nickel (5-1-5)",
        dl == 5 & lb == 2 & db == 4 ~ "Base 5-2",
        dl == 4 & lb == 0 & db == 7 ~ "Dollar (4-0-7)",
        TRUE                        ~ "Other"
      )
    )
}

# ── Defense: Full Season Formation Summary ────────────────────────────────────
