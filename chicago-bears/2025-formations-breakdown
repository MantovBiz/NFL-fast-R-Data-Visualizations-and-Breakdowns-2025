library(nflreadr)
library(nflfastR)
library(tidyverse)
library(gt)
library(gtExtras)
library(webshot2)

# ── Load Data ─────────────────────────────────────────────────────────────────
pbp <- load_participation(2025, include_pbp = TRUE)

# ── Bears Wordmark (used across all tables) ───────────────────────────────────
chi_wordmark <- teams_colors_logos %>%
  filter(team_abbr == "CHI") %>%
  pull(team_wordmark)

# ══════════════════════════════════════════════════════════════════════════════
# OFFENSE
# ══════════════════════════════════════════════════════════════════════════════

# ── Offense: Build Personnel Groups (Full Season) ─────────────────────────────
# Filter to pass and rush plays only to exclude special teams and two point attempts
# Extract RB/FB and TE counts from the personnel string to build a grouping label
# e.g. "1 RB, 1 TE, 3 WR" becomes "11", "1 RB, 2 TE, 2 WR" becomes "12"
pbp_plays <- pbp %>%
  filter(
    pass == 1 | rush == 1,
    play_type %in% c("pass", "run"),
    two_point_attempt == 0
  ) %>%
  mutate(
    rb = rowSums(cbind(
      as.numeric(str_extract(offense_personnel, "(?<= )\\d+(?= RB)")),
      as.numeric(str_extract(offense_personnel, "(?<= )\\d+(?= FB)"))
    ), na.rm = TRUE),
    te = as.numeric(str_extract(offense_personnel, "(?<= )\\d+(?= TE)")) %>% replace_na(0),
    personnel = paste0(rb, te)
  )

# ── Offense: Summarize by Team ────────────────────────────────────────────────
offense_summary <- pbp_plays %>%
  group_by(posteam, personnel) %>%
  summarise(
    Plays   = n(),
    YPP     = mean(yards_gained, na.rm = TRUE),
    EPA     = mean(epa,          na.rm = TRUE),
    Success = mean(success,      na.rm = TRUE),
    .groups = "drop"
  ) %>%
  left_join(teams_colors_logos, by = c("posteam" = "team_abbr"))

# ── Offense: Full Season Table ────────────────────────────────────────────────
offense_table <- offense_summary %>%
  filter(posteam == "CHI") %>%
  select(team_wordmark, personnel, Plays, EPA, Success, YPP) %>%
  arrange(desc(Plays)) %>%
  gt() %>%
  gt_img_rows(columns = team_wordmark) %>%
  fmt_number(columns = c(EPA, YPP), decimals = 2) %>%
  fmt_percent(columns = c(Success), decimals = 2) %>%
  gt_theme_espn() %>%
  opt_row_striping() %>%
  tab_header(title = "Chicago Bears — Offensive Personnel Breakdown (2025 Full Season)") %>%
  tab_caption(caption = "By Manny Tovar | Data via nflverse") %>%
  cols_label(
    team_wordmark = "Team",
    personnel = "Personnel Group"
  )

# ── Offense: Regular Season vs Playoffs Split ─────────────────────────────────
